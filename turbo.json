{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "SERVICE_TASKSYNC",
    "AUTH_AUDIENCE",
    "AUTH_AUTH0_TOKEN_ENDPOINT",
    "AUTH_AUTH0_ID",
    "AUTH_AUTH0_SECRET",
    "AUTH_USERNAME_PASSWORD_URL",
    "AUTH_AUTH0_ISSUER",
    "AUTH0_ISSUER_BASE_URL",
    "LOCAL_AUTH_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
